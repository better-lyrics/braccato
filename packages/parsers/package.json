{
	"name": "@braccato/parsers",
	"version": "0.1.1",
	"description": "Lyrics format parsers: TTML, LRC, SRT, QRC, Plain",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/better-lyrics/braccato",
		"directory": "packages/parsers"
	},
	"homepage": "https://braccato.boidu.dev",
	"keywords": ["lyrics", "parser", "ttml", "lrc", "srt", "qrc"],
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"jsdom": "^28.1.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.7",
		"vite-plugin-dts": "^4.3.0",
		"vitest": "^3.0.4"
	}
}
