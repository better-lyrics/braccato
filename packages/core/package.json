{
	"name": "@braccato/core",
	"version": "0.1.4",
	"description": "Synchronized lyrics web component with word-by-word animations",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/better-lyrics/braccato",
		"directory": "packages/core"
	},
	"homepage": "https://braccato.boidu.dev",
	"keywords": ["lyrics", "sync", "web-component", "lit", "music", "karaoke", "ttml"],
	"sideEffects": true,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@braccato/parsers": "workspace:^",
		"lit": "^3.2.1"
	},
	"devDependencies": {
		"typescript": "^5.7.3",
		"vite": "^6.0.7",
		"vite-plugin-dts": "^4.3.0"
	}
}
